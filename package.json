{
  "name": "typescript-enterprise-boilerplate",
  "version": "1.0.0",
  "description": "Production-ready enterprise backend boilerplate in TypeScript — Clean Architecture, DDD, TDD.",
  "author": "Ilton Seixas <contact@iltonseixas.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "bun dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "test": "bun test --path-ignore-patterns '**/*.integration.spec.ts' src",
    "test:watch": "bun test --watch --path-ignore-patterns '**/*.integration.spec.ts' src",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text --path-ignore-patterns '**/*.integration.spec.ts' src",
    "test:integration": "bun test src/interfaces/grpc/server.integration.spec.ts",
    "test:all": "bun run test && bun run test:integration"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.219.0",
    "@opentelemetry/instrumentation-fastify": "^0.57.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "drizzle-kit": "0.31.10",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "trustedDependencies": [
    "esbuild",
    "protobufjs"
  ],
  "overrides": {
    "esbuild": "^0.25.4"
  }
}
