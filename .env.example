# Server
HOST=0.0.0.0
PORT=3000
GRPC_PORT=50051

# Persistence — "memory" requires no database; "postgres" requires DATABASE_URL
ADAPTER=memory

# PostgreSQL (required when ADAPTER=postgres)
DATABASE_URL=postgres://user:password@localhost:5432/boilerplate
DATABASE_POOL_MAX=10
DATABASE_POOL_MIN=2

# Redis (required when ADAPTER=postgres)
REDIS_URL=redis://localhost:6379

# Authentication — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-value-minimum-32-characters
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4321
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=typescript-enterprise-boilerplate
OTEL_SERVICE_VERSION=0.1.0
