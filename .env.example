# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
GRPC_PORT=50051

# Authentication — JWT signed with EdDSA (Ed25519). Generate a key pair with:
#   openssl genpkey -algorithm ed25519 -out jwt_private.pem
#   openssl pkey -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY_PATH=./jwt_private.pem
JWT_PUBLIC_KEY_PATH=./jwt_public.pem
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Redis (refresh token storage)
REDIS_URL=redis://localhost:6379

# PostgreSQL connection pool (only used when DATABASE_URL is set)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_CONNECT_TIMEOUT_SECONDS=30
DB_POOL_IDLE_TIMEOUT_SECONDS=600
DB_POOL_MAX_LIFETIME_SECONDS=1800

# Redis connection/command timeouts
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_COMMAND_TIMEOUT_MS=2000

# Postgres (optional — if unset, an in-memory repository is used instead)
# DATABASE_URL=postgres://boilerplate:boilerplate@localhost:5432/boilerplate

# Security — comma-separated list of allowed CORS origins (empty disables CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4321

# Optional bearer token required to access /metrics (unset leaves it open)
# METRICS_TOKEN=change-me

# Observability
OTLP_ENDPOINT=http://localhost:4317
